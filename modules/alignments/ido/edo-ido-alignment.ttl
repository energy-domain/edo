@prefix edo: <https://w3id.org/energy-domain/edo#> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://w3id.org/energy-domain/edo/alignments/ido>
    a owl:Ontology ;
    rdfs:label "EDO to IDO Alignment" ;
    dcterms:description """
    Alignment module relating the Energy Domain Ontology (EDO)
    to the Industrial Data Ontology (IDO/LIS-14) published by POSC Caesar.
    This module provides non-invasive references from EDO domain concepts
    and relationship annotations to upper-level IDO categories.
    """ .

edo:idoReference
    a owl:AnnotationProperty ;
    rdfs:label "IDO reference" ;
    rdfs:comment """
    Relates an EDO entity to a relevant IDO entity without necessarily
    asserting formal equivalence or subclassing.
    """ .

edo:Asset
    edo:idoReference lis:PhysicalArtefact .

edo:SubseaSystem
    edo:idoReference lis:System .

edo:FlexiblePipeSegment
    edo:idoReference lis:PhysicalArtefact .

edo:EndFitting
    edo:idoReference lis:PhysicalArtefact .

edo:LineAncillary
    edo:idoReference lis:PhysicalArtefact .

edo:FluidStream
    edo:idoReference lis:Stream .

edo:Pressure
    edo:idoReference lis:PhysicalQuantity .

edo:hasPart
    edo:idoReference lis:hasPart .

edo:hasFunctionalPart
    edo:idoReference lis:hasFunctionalPart .

edo:isConnectedTo
    edo:idoReference lis:connectedTo .

edo:hasContainedElement
    edo:idoReference lis:contains .
