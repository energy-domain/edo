@prefix edo: <https://w3id.org/energy-domain/edo#> .
@prefix lis: <http://rds.posccaesar.org/ontology/lis14/rdl/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://w3id.org/energy-domain/edo/alignments/ido>
    a owl:Ontology ;
    rdfs:label "EDO to IDO Alignment" ;
    dcterms:description """
    Alignment module relating the Energy Domain Ontology (EDO)
    to the Industrial Data Ontology (IDO/LIS-14) published by POSC Caesar.
    This module keeps the alignment outside the EDO core and uses SKOS mapping
    properties to provide non-invasive references from EDO domain concepts,
    attributes and relationship annotations to upper-level IDO categories.
    """ .

#################################################################
#    Core domain entities
#################################################################

edo:Asset
    skos:closeMatch lis:PhysicalArtefact .

edo:SubseaSystem
    skos:closeMatch lis:System .

edo:FlexiblePipeSegment
    skos:closeMatch lis:PhysicalArtefact .

edo:EndFitting
    skos:closeMatch lis:PhysicalArtefact .

edo:LineAncillary
    skos:closeMatch lis:PhysicalArtefact .

edo:FluidStream
    skos:closeMatch lis:Stream .

#################################################################
#    Technical artifacts, specifications and configurations
#################################################################

edo:TechnicalArtifact
    skos:closeMatch lis:InformationObject .

edo:Specification
    skos:closeMatch lis:PrescriptiveObject .

edo:ConfiguredSystem
    skos:closeMatch lis:System .

edo:FlexibleStructure
    skos:closeMatch lis:System .

#################################################################
#    Features and interface points
#################################################################

edo:Feature
    skos:closeMatch lis:Feature .

edo:ConnectionPoint
    skos:closeMatch lis:Feature .

edo:AttachmentPoint
    skos:closeMatch lis:Feature .

edo:ReferencePoint
    skos:closeMatch lis:Feature .

edo:Port
    skos:closeMatch lis:Feature .

#################################################################
#    Domain attributes and physical quantities
#################################################################

edo:DomainAttribute
    skos:closeMatch lis:Quality .

edo:Pressure
    skos:closeMatch lis:PhysicalQuantity .

edo:WaterDepth
    skos:closeMatch lis:PhysicalQuantity .

edo:MaxWaterDepth
    skos:closeMatch lis:PhysicalQuantity .

edo:RequiredMaxWaterDepth
    skos:closeMatch lis:PhysicalQuantity .

edo:DesignedMaxWaterDepth
    skos:closeMatch lis:PhysicalQuantity .

edo:CertifiedMaxWaterDepth
    skos:closeMatch lis:PhysicalQuantity .

edo:InstalledWaterDepth
    skos:closeMatch lis:PhysicalQuantity .

#################################################################
#    Attribute classification schemes
#################################################################

edo:DomainAttributeRole
    skos:relatedMatch lis:Role .

edo:DomainAttributeNature
    skos:relatedMatch lis:Quality .

edo:CapabilityAttribute
    skos:relatedMatch lis:Capability .

edo:DimensionalAttribute
    skos:relatedMatch lis:PhysicalQuantity .

edo:LocationAttribute
    skos:relatedMatch lis:Location .

#################################################################
#    Domain relationship annotations
#################################################################

edo:hasPart
    skos:closeMatch lis:hasPart .

edo:hasOrderedPart
    skos:relatedMatch lis:hasArrangedPart .

edo:hasFunctionalPart
    skos:closeMatch lis:hasFunctionalPart .

edo:isConnectedTo
    skos:closeMatch lis:connectedTo .

edo:hasConnectionPoint
    skos:closeMatch lis:hasFeature .

edo:hasContainedElement
    skos:closeMatch lis:contains .

edo:hasDocument
    skos:relatedMatch lis:representedIn .
