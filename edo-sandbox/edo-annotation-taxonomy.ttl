### 5.2 Interoperability support

edo:equivalentExternalProperty
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo:DomainInteroperabilityAnnotation ;
    rdfs:label "Equivalent External Property"@en ;
    rdfs:label "Propriedade Externa Equivalente"@pt-br ;
    skos:definition "Links an EDO property to an equivalent external property from another vocabulary or standard."@en ;
    skos:definition "Vincula uma propriedade da EDO a uma propriedade externa equivalente de outro vocabulário ou padrão."@pt-br ;
    skos:altLabel "External Equivalent"@en ;
    skos:altLabel "Equivalente Externo"@pt-br ;
    dcterms:identifier "equivalentExternalProperty" .

edo:hasExternalRef
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo:DomainInteroperabilityAnnotation ;
    rdfs:label "Has External Reference"@en ;
    rdfs:label "Tem Referência Externa"@pt-br ;
    skos:definition "Associates an EDO entity with an equivalent or corresponding concept defined in an external data dictionary, ontology, classification system or engineering standard."@en ;
    skos:definition "Associa uma entidade da EDO a um conceito equivalente ou correspondente definido em um dicionário de dados, ontologia, sistema de classificação ou norma de engenharia externa."@pt-br ;
    skos:altLabel "External Reference"@en ;
    skos:altLabel "Referência Externa"@pt-br ;
    skos:altLabel "External Mapping"@en ;
    skos:altLabel "Mapeamento Externo"@pt-br ;
    skos:example "Example: linking an EDO class to an equivalent concept in an external classification system."@en ;
    skos:example "Exemplo: vincular uma classe da EDO a um conceito equivalente em um sistema de classificação externo."@pt-br ;
    dcterms:identifier "hasExternalRef" .

### 5.3 Governance support

# edo:entityStatus
#     rdf:type owl:AnnotationProperty ;
#     rdfs:subPropertyOf edo:DomainGovernanceAnnotation ;
#     rdfs:label "Entity Status"@en ;
#     rdfs:label "Status da Entidade"@pt-br ;
#     skos:definition "Annotation used to indicate the governance and editorial status of an entity within the Energy Domain Ontology, representing its level of maturity in the approval process."@en ;
#     skos:definition "Anotação usada para indicar o status de governança e editorial de uma entidade dentro da Energy Domain Ontology, representando seu nível de maturidade no processo de aprovação."@pt-br ;
#     skos:altLabel "Governance Status"@en ;
#     skos:altLabel "Situação da Entidade"@pt-br ;
#     skos:example "Typical values include: NEW, REVIEW, APPROVED."@en ;
#     skos:example "Valores típicos incluem: NOVO, ANALISANDO, APROVADO."@pt-br ;
#     dcterms:identifier "entityStatus" .

edo:EntityMaturityLevel
    rdf:type owl:Class ;
    rdfs:label "Entity Maturity Level"@en ;
    rdfs:label "Nível de Maturidade da Entidade"@pt-br ;
    skos:altLabel "Editorial Maturity Level"@en ;
    skos:altLabel "Nível de Maturidade Editorial"@pt-br ;
    skos:definition "Controlled vocabulary for editorial maturity levels of entities in the Energy Domain Ontology."@en ;
    skos:definition "Vocabulário controlado para níveis de maturidade editorial de entidades da Energy Domain Ontology."@pt-br ;
    skos:example "Example values include Proposed, UnderReview, Consolidated, Published and Deprecated."@en ;
    skos:example "Exemplos de valores incluem Proposed, UnderReview, Consolidated, Published e Deprecated."@pt-br ;
    dcterms:identifier "EntityMaturityLevel" .

edo:Proposed
    rdf:type owl:NamedIndividual ;
    rdf:type edo:EntityMaturityLevel ;
    rdfs:label "Proposed"@en ;
    rdfs:label "Proposto"@pt-br ;
    skos:altLabel "Draft Proposal"@en ;
    skos:altLabel "Proposta Inicial"@pt-br ;
    skos:definition "Entity proposed for inclusion or change, not yet reviewed or consolidated."@en ;
    skos:definition "Entidade proposta para inclusão ou alteração, ainda não revisada nem consolidada."@pt-br ;
    skos:example "Example: a new domain class introduced by a modeller before formal technical review."@en ;
    skos:example "Exemplo: uma nova classe de domínio introduzida por um modelador antes da revisão técnica formal."@pt-br ;
    dcterms:identifier "Proposed" .

edo:UnderReview
    rdf:type owl:NamedIndividual ;
    rdf:type edo:EntityMaturityLevel ;
    rdfs:label "Under Review"@en ;
    rdfs:label "Em Revisão"@pt-br ;
    skos:altLabel "In Review"@en ;
    skos:altLabel "Em Análise"@pt-br ;
    skos:definition "Entity currently under technical, editorial or domain review."@en ;
    skos:definition "Entidade atualmente em revisão técnica, editorial ou de domínio."@pt-br ;
    skos:example "Example: a proposed relation being evaluated by domain specialists before consolidation."@en ;
    skos:example "Exemplo: uma relação proposta sendo avaliada por especialistas de domínio antes da consolidação."@pt-br ;
    dcterms:identifier "UnderReview" .

edo:Consolidated
    rdf:type owl:NamedIndividual ;
    rdf:type edo:EntityMaturityLevel ;
    rdfs:label "Consolidated"@en ;
    rdfs:label "Consolidado"@pt-br ;
    skos:altLabel "Stabilised"@en ;
    skos:altLabel "Estabilizado"@pt-br ;
    skos:definition "Entity reviewed and stabilised in the working ontology, but not necessarily included in an official published release."@en ;
    skos:definition "Entidade revisada e estabilizada na ontologia de trabalho, mas não necessariamente incluída em uma release oficial publicada."@pt-br ;
    skos:example "Example: a class approved by the modelling team but not yet included in a formal release package."@en ;
    skos:example "Exemplo: uma classe aprovada pela equipe de modelagem, mas ainda não incluída em um pacote formal de release."@pt-br ;
    dcterms:identifier "Consolidated" .

edo:Published
    rdf:type owl:NamedIndividual ;
    rdf:type edo:EntityMaturityLevel ;
    rdfs:label "Published"@en ;
    rdfs:label "Publicado"@pt-br ;
    skos:altLabel "Released"@en ;
    skos:altLabel "Publicado em Release"@pt-br ;
    skos:definition "Entity included in an official published release of the Energy Domain Ontology."@en ;
    skos:definition "Entidade incluída em uma release oficial publicada da Energy Domain Ontology."@pt-br ;
    skos:example "Example: a domain attribute included in a released EDO version used to generate a data dictionary."@en ;
    skos:example "Exemplo: um atributo de domínio incluído em uma versão publicada da EDO usada para gerar um dicionário de dados."@pt-br ;
    dcterms:identifier "Published" .

edo:Deprecated
    rdf:type owl:NamedIndividual ;
    rdf:type edo:EntityMaturityLevel ;
    rdfs:label "Deprecated"@en ;
    rdfs:label "Descontinuado"@pt-br ;
    skos:altLabel "Not Recommended"@en ;
    skos:altLabel "Não Recomendado"@pt-br ;
    skos:definition "Entity kept for traceability but no longer recommended for use."@en ;
    skos:definition "Entidade mantida para rastreabilidade, mas não mais recomendada para uso."@pt-br ;
    skos:example "Example: an older attribute kept for compatibility with previous releases but replaced by a newer concept."@en ;
    skos:example "Exemplo: um atributo antigo mantido para compatibilidade com releases anteriores, mas substituído por um conceito mais novo."@pt-br ;
    dcterms:identifier "Deprecated" .

### 5.4 Attribute structure support (used by attributes referenced by relations/contracts)

edo:hasUnit
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo:DomainAttributeStructureAnnotation ;
    rdfs:label "Has Unit"@en ;
    rdfs:label "Tem Unidade"@pt-br ;
    skos:definition "Relates a DomainAttribute to the measurement unit in which its values are expressed."@en ;
    skos:definition "Relaciona um DomainAttribute à unidade de medida na qual seus valores são expressos."@pt-br ;
    skos:altLabel "Unit Of Measure"@en ;
    skos:altLabel "Unidade de Medida"@pt-br ;
    rdfs:domain edo:DomainAttribute ;
    rdfs:range edo:DomainUnit ;
    dcterms:identifier "hasUnit" .