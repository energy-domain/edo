diff --git a/core/edo.ttl b/core/edo.ttl
index d331ff1..6dd1d90 100644
--- a/core/edo.ttl
+++ b/core/edo.ttl
@@ -1041,6 +1041,16 @@ edo:Asset rdf:type owl:Class ;
                            edo:SerialNumber .
 
 
+###  https://w3id.org/energy-domain/edo#AttachmentPoint
+edo:AttachmentPoint rdf:type owl:Class ;
+                    rdfs:subClassOf edo:Feature ;
+                    dcterms:identifier "AttachmentPoint" ;
+                    skos:definition "Feature that represents a point intended for attaching, mounting or positioning an ancillary element without implying a physical flow connection."@en ,
+                                    "Feature que representa um ponto destinado à anexação, montagem ou posicionamento de um elemento acessório, sem implicar conexão física de fluxo."@pt-br ;
+                    skos:prefLabel "Attachment Point"@en ,
+                                   "Ponto de Anexação"@pt-br .
+
+
 ###  https://w3id.org/energy-domain/edo#AttributeClassification
 edo:AttributeClassification rdf:type owl:Class ;
                             rdfs:subClassOf edo:DomainClassification ;
@@ -1831,7 +1841,7 @@ edo:ConnectionModule rdf:type owl:Class ;
 
 ###  https://w3id.org/energy-domain/edo#ConnectionPoint
 edo:ConnectionPoint rdf:type owl:Class ;
-                    rdfs:subClassOf edo:LogicalElement ;
+                    rdfs:subClassOf edo:Feature ;
                     dcterms:identifier "ConnectionPoint" ;
                     skos:definition "Representa um ponto utilizado para estabelecer conexão entre elementos, seja fisicamente ou logicamente."@pt-br ,
                                     "Represents a point used to establish a connection between elements, either physically or logically."@en ;
@@ -3200,6 +3210,16 @@ edo:FatNomPressValRefMult rdf:type owl:Class ;
                           edo:hasValueCardinality edo:SingleValue .
 
 
+###  https://w3id.org/energy-domain/edo#Feature
+edo:Feature rdf:type owl:Class ;
+            rdfs:subClassOf edo:DomainElement ;
+            dcterms:identifier "Feature" ;
+            skos:definition "Domain element that represents a dependent feature, interface, point or region of another element, used to support connection, attachment, reference, positioning or interaction."@en ,
+                            "Elemento de domínio que representa uma feature, interface, ponto ou região dependente de outro elemento, usada para apoiar conexão, anexação, referência, posicionamento ou interação."@pt-br ;
+            skos:prefLabel "Feature"@en ,
+                           "Feature"@pt-br .
+
+
 ###  https://w3id.org/energy-domain/edo#FiberOpticJumper
 edo:FiberOpticJumper rdf:type owl:Class ;
                      rdfs:subClassOf edo:LinearObject ;
@@ -6645,7 +6665,7 @@ edo:PolymericMaterial rdf:type owl:Class ;
 
 ###  https://w3id.org/energy-domain/edo#Port
 edo:Port rdf:type owl:Class ;
-         rdfs:subClassOf edo:LogicalElement ;
+         rdfs:subClassOf edo:Feature ;
          skos:definition "Representa um ponto de interface através do qual um elemento pode trocar dados, energia ou fluidos."@pt-br ,
                          "Represents an interface point through which an element can exchange data, energy, or fluids."@en ;
          skos:prefLabel "Port"@en ,
@@ -6998,6 +7018,16 @@ edo:RearPoint rdf:type owl:Class ;
                                 edo:SubseaUmbilicalsEngineering .
 
 
+###  https://w3id.org/energy-domain/edo#ReferencePoint
+edo:ReferencePoint rdf:type owl:Class ;
+                   rdfs:subClassOf edo:Feature ;
+                   dcterms:identifier "ReferencePoint" ;
+                   skos:definition "Feature used as a reference point for orientation, positioning, measurement or interpretation of another feature or element."@en ,
+                                   "Feature usada como ponto de referência para orientação, posicionamento, medição ou interpretação de outra feature ou elemento."@pt-br ;
+                   skos:prefLabel "Reference Point"@en ,
+                                  "Ponto de Referência"@pt-br .
+
+
 ###  https://w3id.org/energy-domain/edo#Recycling
 edo:Recycling rdf:type owl:Class ;
               rdfs:subClassOf edo:DecommissioningPhase ;
