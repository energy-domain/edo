diff --git a/queries/refactoring/01-core-no-legacy-ifc-properties.rq b/queries/refactoring/01-core-no-legacy-ifc-properties.rq
new file mode 100644
index 0000000..faee3c7
--- /dev/null
+++ b/queries/refactoring/01-core-no-legacy-ifc-properties.rq
@@ -0,0 +1,17 @@
+PREFIX edo: <https://w3id.org/energy-domain/edo#>
+
+# Run against: core/edo.ttl
+# Expected result: empty.
+# Finds legacy IFC mapping annotations that must not remain in the EDO core.
+
+SELECT ?subject ?property ?object
+WHERE {
+  VALUES ?property {
+    edo:ifc_equivalentClass
+    edo:ifc_objectType
+    edo:ifc_predefinedType
+  }
+
+  ?subject ?property ?object .
+}
+ORDER BY ?subject ?property ?object
diff --git a/queries/refactoring/02-core-no-edo-ifc-namespace.rq b/queries/refactoring/02-core-no-edo-ifc-namespace.rq
new file mode 100644
index 0000000..bb73995
--- /dev/null
+++ b/queries/refactoring/02-core-no-edo-ifc-namespace.rq
@@ -0,0 +1,17 @@
+PREFIX edo-ifc: <https://w3id.org/energy-domain/edo-ifc#>
+
+# Run against: core/edo.ttl
+# Expected result: empty.
+# Finds references from the EDO core to EDO-IFC resources.
+
+SELECT ?subject ?property ?object
+WHERE {
+  ?subject ?property ?object .
+
+  FILTER (
+    STRSTARTS(STR(?subject), STR(edo-ifc:)) ||
+    STRSTARTS(STR(?property), STR(edo-ifc:)) ||
+    STRSTARTS(STR(?object), STR(edo-ifc:))
+  )
+}
+ORDER BY ?subject ?property ?object
diff --git a/queries/refactoring/03-datatypes-no-owl-restrictions.rq b/queries/refactoring/03-datatypes-no-owl-restrictions.rq
new file mode 100644
index 0000000..9a34b23
--- /dev/null
+++ b/queries/refactoring/03-datatypes-no-owl-restrictions.rq
@@ -0,0 +1,21 @@
+PREFIX edo: <https://w3id.org/energy-domain/edo#>
+PREFIX owl: <http://www.w3.org/2002/07/owl#>
+PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
+
+# Run against: core/edo.ttl
+# Expected result: empty.
+# DataTypes should declare their expected XSD type with edo:expectedXsdType,
+# not through OWL restrictions.
+
+SELECT ?datatype ?predicate ?restriction
+WHERE {
+  ?datatype rdfs:subClassOf* edo:DataType .
+  ?datatype ?predicate ?restriction .
+  ?restriction a owl:Restriction .
+
+  VALUES ?predicate {
+    rdfs:subClassOf
+    owl:equivalentClass
+  }
+}
+ORDER BY ?datatype ?predicate
diff --git a/queries/refactoring/04-domain-attributes-missing-hasTypedValue.rq b/queries/refactoring/04-domain-attributes-missing-hasTypedValue.rq
new file mode 100644
index 0000000..6c6e808
--- /dev/null
+++ b/queries/refactoring/04-domain-attributes-missing-hasTypedValue.rq
@@ -0,0 +1,16 @@
+PREFIX edo: <https://w3id.org/energy-domain/edo#>
+PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
+
+# Run against: core/edo.ttl
+# Expected result: review list.
+# Finds DomainAttribute classes without an explicit value type.
+
+SELECT ?attribute
+WHERE {
+  ?attribute rdfs:subClassOf+ edo:DomainAttribute .
+
+  FILTER NOT EXISTS {
+    ?attribute edo:hasTypedValue ?valueType .
+  }
+}
+ORDER BY ?attribute
