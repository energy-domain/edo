+
+edo:LocationAttribute
+    skos:relatedMatch lis:Location .
+
+#################################################################
+#    Domain relationship annotations
+#################################################################
 
 edo:hasPart
-    edo:idoReference lis:hasPart .
+    skos:closeMatch lis:hasPart .
+
+edo:hasOrderedPart
+    skos:relatedMatch lis:hasArrangedPart .
 
 edo:hasFunctionalPart
-    edo:idoReference lis:hasFunctionalPart .
+    skos:closeMatch lis:hasFunctionalPart .
 
 edo:isConnectedTo
-    edo:idoReference lis:connectedTo .
+    skos:closeMatch lis:connectedTo .
+
+edo:hasConnectionPoint
+    skos:closeMatch lis:hasFeature .
 
 edo:hasContainedElement
