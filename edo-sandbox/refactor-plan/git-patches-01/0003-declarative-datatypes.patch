+######################################################################
+# 11) Direct IFC mappings for EDO datatypes
+######################################################################
+
+edo:AnyURIType
+    edo-ifc:ifc_equivalentClass edo-ifc:IfcText .
+
+edo:BooleanValue
+    edo-ifc:ifc_equivalentClass edo-ifc:IfcBoolean .
+
+edo:DateTimeValue
