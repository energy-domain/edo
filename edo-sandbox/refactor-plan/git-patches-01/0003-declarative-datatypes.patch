+    rdfs:subClassOf edo-ifc:IFCEntity ;
+    rdfs:label "IFC Value Type"@en ;
+    skos:definition "Controlled concept representing an IFC value type used by EDO-IFC datatype mappings."@en ;
+    dcterms:identifier "IFCValueType" .
+
+edo-ifc:IfcBoolean
+    rdf:type owl:NamedIndividual ;
+    rdf:type edo-ifc:IFCValueType ;
+    rdfs:label "IfcBoolean"@en ;
+    edo-ifc:ifcEntityName "IfcBoolean" ;
+    dcterms:identifier "IfcBoolean" .
+
+edo-ifc:IfcDateTime
+    rdf:type owl:NamedIndividual ;
+    rdf:type edo-ifc:IFCValueType ;
+    rdfs:label "IfcDateTime"@en ;
+    edo-ifc:ifcEntityName "IfcDateTime" ;
+    dcterms:identifier "IfcDateTime" .
+
+edo-ifc:IfcDate
+    rdf:type owl:NamedIndividual ;
+    rdf:type edo-ifc:IFCValueType ;
+    rdfs:label "IfcDate"@en ;
+    edo-ifc:ifcEntityName "IfcDate" ;
+    dcterms:identifier "IfcDate" .
+
+edo-ifc:IfcReal
+    rdf:type owl:NamedIndividual ;
+    rdf:type edo-ifc:IFCValueType ;
+    rdfs:label "IfcReal"@en ;
+    edo-ifc:ifcEntityName "IfcReal" ;
+    dcterms:identifier "IfcReal" .
+
+edo-ifc:IfcInteger
+    rdf:type owl:NamedIndividual ;
+    rdf:type edo-ifc:IFCValueType ;
+    rdfs:label "IfcInteger"@en ;
+    edo-ifc:ifcEntityName "IfcInteger" ;
+    dcterms:identifier "IfcInteger" .
+
+edo-ifc:IfcText
+    rdf:type owl:NamedIndividual ;
+    rdf:type edo-ifc:IFCValueType ;
+    rdfs:label "IfcText"@en ;
+    edo-ifc:ifcEntityName "IfcText" ;
+    dcterms:identifier "IfcText" .
+
+edo-ifc:IfcTime
+    rdf:type owl:NamedIndividual ;
+    rdf:type edo-ifc:IFCValueType ;
+    rdfs:label "IfcTime"@en ;
+    edo-ifc:ifcEntityName "IfcTime" ;
+    dcterms:identifier "IfcTime" .
