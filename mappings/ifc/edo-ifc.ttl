    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelAssociatesDocument.htm> ;

    dcterms:identifier "IfcRelAssociatesDocument" .


edo-ifc:IfcRelAssociatesClassification
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCRelationshipEntity ;

    rdfs:label "IfcRelAssociatesClassification"@en ;
    edo-ifc:ifcEntityName "IfcRelAssociatesClassification" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelAssociatesClassification.htm> ;

    dcterms:identifier "IfcRelAssociatesClassification" .


edo-ifc:IfcRelAssociatesMaterial
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCRelationshipEntity ;

    rdfs:label "IfcRelAssociatesMaterial"@en ;
    edo-ifc:ifcEntityName "IfcRelAssociatesMaterial" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelAssociatesMaterial.htm> ;

    dcterms:identifier "IfcRelAssociatesMaterial" .


edo-ifc:IfcRelAssignsToGroup
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCRelationshipEntity ;

    rdfs:label "IfcRelAssignsToGroup"@en ;
    edo-ifc:ifcEntityName "IfcRelAssignsToGroup" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelAssignsToGroup.htm> ;

    dcterms:identifier "IfcRelAssignsToGroup" .


edo-ifc:IfcRelAssignsToProduct
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCRelationshipEntity ;

    rdfs:label "IfcRelAssignsToProduct"@en ;
    edo-ifc:ifcEntityName "IfcRelAssignsToProduct" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelAssignsToProduct.htm> ;

    dcterms:identifier "IfcRelAssignsToProduct" .


edo-ifc:IfcRelConnectsPorts
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCRelationshipEntity ;

    rdfs:label "IfcRelConnectsPorts"@en ;
    edo-ifc:ifcEntityName "IfcRelConnectsPorts" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelConnectsPorts.htm> ;

    dcterms:identifier "IfcRelConnectsPorts" .


edo-ifc:IfcRelConnectsElements
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCRelationshipEntity ;

    rdfs:label "IfcRelConnectsElements"@en ;
    edo-ifc:ifcEntityName "IfcRelConnectsElements" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelConnectsElements.htm> ;

    dcterms:identifier "IfcRelConnectsElements" .


edo-ifc:IfcRelConnectsWithRealizingElements
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCRelationshipEntity ;

    rdfs:label "IfcRelConnectsWithRealizingElements"@en ;
    edo-ifc:ifcEntityName "IfcRelConnectsWithRealizingElements" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelConnectsWithRealizingElements.htm> ;

    dcterms:identifier "IfcRelConnectsWithRealizingElements" .

######################################################################
# 8) Controlled IFC object entities
######################################################################

edo-ifc:IfcDistributionPort
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCObjectEntity ;

    rdfs:label "IfcDistributionPort"@en ;
    edo-ifc:ifcEntityName "IfcDistributionPort" ;

    skos:exactMatch <https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/class/IfcDistributionPort> ;
    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcDistributionPort.htm> ;

    dcterms:identifier "IfcDistributionPort" .


edo-ifc:IfcPipeSegment
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCObjectEntity ;

    rdfs:label "IfcPipeSegment"@en ;
    edo-ifc:ifcEntityName "IfcPipeSegment" ;

    skos:exactMatch <https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/class/IfcPipeSegment> ;
    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcPipeSegment.htm> ;

    dcterms:identifier "IfcPipeSegment" .

