    dcterms:identifier "RelatedObjects" .


edo-ifc:RelatingDocument
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatingDocument"@en ;
    edo-ifc:ifcAttributeName "RelatingDocument" ;

    dcterms:identifier "RelatingDocument" .


edo-ifc:RelatingClassification
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatingClassification"@en ;
    edo-ifc:ifcAttributeName "RelatingClassification" ;

    dcterms:identifier "RelatingClassification" .


edo-ifc:RelatingMaterial
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatingMaterial"@en ;
    edo-ifc:ifcAttributeName "RelatingMaterial" ;

    dcterms:identifier "RelatingMaterial" .


edo-ifc:RelatingGroup
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatingGroup"@en ;
    edo-ifc:ifcAttributeName "RelatingGroup" ;

    dcterms:identifier "RelatingGroup" .


edo-ifc:RelatingProduct
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatingProduct"@en ;
    edo-ifc:ifcAttributeName "RelatingProduct" ;

    dcterms:identifier "RelatingProduct" .


edo-ifc:RelatingPort
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatingPort"@en ;
    edo-ifc:ifcAttributeName "RelatingPort" ;

    dcterms:identifier "RelatingPort" .


edo-ifc:RelatedPort
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatedPort"@en ;
    edo-ifc:ifcAttributeName "RelatedPort" ;

    dcterms:identifier "RelatedPort" .


edo-ifc:RelatingElement
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatingElement"@en ;
    edo-ifc:ifcAttributeName "RelatingElement" ;

    dcterms:identifier "RelatingElement" .


edo-ifc:RelatedElement
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatedElement"@en ;
