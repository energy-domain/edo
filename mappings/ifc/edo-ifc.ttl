    edo-ifc:ifcEntityName "IfcClassificationReference" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcClassificationReference.htm> ;

