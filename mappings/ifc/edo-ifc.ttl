    dcterms:identifier "IfcRelConnectsWithRealizingElements" .

######################################################################
# 8) Controlled IFC object entities
######################################################################

edo-ifc:IfcDistributionPort
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCObjectEntity ;

    rdfs:label "IfcDistributionPort"@en ;
