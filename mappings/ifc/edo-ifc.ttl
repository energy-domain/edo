######################################################################
# 11) Direct IFC mappings for EDO relationships
######################################################################

edo:hasPart
    edo-ifc:ifc_equivalentClass edo-ifc:IfcRelAggregates ;
    edo-ifc:ifc_subjectRole edo-ifc:RelatingObject ;
    edo-ifc:ifc_objectRole edo-ifc:RelatedObjects .

edo:hasOrderedPart
    edo-ifc:ifc_equivalentClass edo-ifc:IfcRelNests ;
    edo-ifc:ifc_subjectRole edo-ifc:RelatingObject ;
    edo-ifc:ifc_objectRole edo-ifc:RelatedObjects .

edo:hasDocument
    edo-ifc:ifc_equivalentClass edo-ifc:IfcRelAssociatesDocument ;
    edo-ifc:ifc_subjectRole edo-ifc:RelatedObjects ;
    edo-ifc:ifc_objectRole edo-ifc:RelatingDocument .

edo:hasClassificationReference
    edo-ifc:ifc_equivalentClass edo-ifc:IfcRelAssociatesClassification ;
    edo-ifc:ifc_subjectRole edo-ifc:RelatedObjects ;
    edo-ifc:ifc_objectRole edo-ifc:RelatingClassification .

edo:hasMaterial
    edo-ifc:ifc_equivalentClass edo-ifc:IfcRelAssociatesMaterial ;
    edo-ifc:ifc_subjectRole edo-ifc:RelatedObjects ;
    edo-ifc:ifc_objectRole edo-ifc:RelatingMaterial .

edo:belongsToGroup
    edo-ifc:ifc_equivalentClass edo-ifc:IfcRelAssignsToGroup ;
    edo-ifc:ifc_subjectRole edo-ifc:RelatedObjects ;
    edo-ifc:ifc_objectRole edo-ifc:RelatingGroup .

edo:hasSparePart
    edo-ifc:ifc_equivalentClass edo-ifc:IfcRelAssignsToProduct ;
    edo-ifc:ifc_invertedDirection "true"^^xsd:boolean ;
    edo-ifc:ifc_subjectRole edo-ifc:RelatingProduct ;
    edo-ifc:ifc_objectRole edo-ifc:RelatedObjects .

######################################################################
# 12) Conditional IFC materialisation rules for edo:isConnectedTo
#
# Logic:
#
# 1. Port + Port:
#    - Always materialise as IfcRelConnectsPorts.
#    - If realizing elements exist, they fill IfcRelConnectsPorts.RealizingElement.
#
# 2. Non-port + Non-port:
#    - Without realizing elements: IfcRelConnectsElements.
#    - With realizing elements: IfcRelConnectsWithRealizingElements.
#
# The negative condition is IFC-specific and therefore lives here,
# not in the EDO core.
######################################################################

edo:isConnectedTo
    edo-ifc:ifc_mappingRule [
        edo-ifc:sourceIfcEquivalentClass edo-ifc:IfcDistributionPort ;
        edo-ifc:targetIfcEquivalentClass edo-ifc:IfcDistributionPort ;
        edo-ifc:realizingElementRequirement edo-ifc:AnyRealizingElementRequirement ;
        edo-ifc:ifc_equivalentClass edo-ifc:IfcRelConnectsPorts ;
        edo-ifc:ifc_subjectRole edo-ifc:RelatingPort ;
        edo-ifc:ifc_objectRole edo-ifc:RelatedPort ;
        edo-ifc:realizingElementRole edo-ifc:RealizingElement
    ] ;

    edo-ifc:ifc_mappingRule [
        edo-ifc:sourceNotIfcEquivalentClass edo-ifc:IfcDistributionPort ;
        edo-ifc:targetNotIfcEquivalentClass edo-ifc:IfcDistributionPort ;
        edo-ifc:realizingElementRequirement edo-ifc:DoesNotRequireRealizingElements ;
        edo-ifc:ifc_equivalentClass edo-ifc:IfcRelConnectsElements ;
        edo-ifc:ifc_subjectRole edo-ifc:RelatingElement ;
        edo-ifc:ifc_objectRole edo-ifc:RelatedElement
    ] ;

    edo-ifc:ifc_mappingRule [
        edo-ifc:sourceNotIfcEquivalentClass edo-ifc:IfcDistributionPort ;
        edo-ifc:targetNotIfcEquivalentClass edo-ifc:IfcDistributionPort ;
        edo-ifc:realizingElementRequirement edo-ifc:RequiresRealizingElements ;
        edo-ifc:ifc_equivalentClass edo-ifc:IfcRelConnectsWithRealizingElements ;
        edo-ifc:ifc_subjectRole edo-ifc:RelatingElement ;
        edo-ifc:ifc_objectRole edo-ifc:RelatedElement ;
        edo-ifc:realizingElementRole edo-ifc:RealizingElements
    ] .