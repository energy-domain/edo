    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

    rdfs:label "RelatingObject"@en ;
    edo-ifc:ifcAttributeName "RelatingObject" ;

    dcterms:identifier "RelatingObject" .


edo-ifc:RelatedObjects
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCAttributeRole ;

