@prefix edo: <https://w3id.org/energy-domain/edo#> .
@prefix edo-ifc: <https://w3id.org/energy-domain/edo/mappings/ifc#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

######################################################################
# EDO-IFC — Mapping ontology
#
# Scope:
# - Imports/uses EDO core.
# - Defines IFC-specific mapping annotations.
# - Defines controlled IFC entities and IFC attribute roles used by mappings.
# - Declares IFC materialisation rules for EDO relationships.
#
# Important:
# - This ontology is the source of truth for EDO → IFC mapping.
# - EDO core remains independent of IFC.
# - IFC classes and roles are represented as controlled resources, not strings.
######################################################################

######################################################################
# 1) Ontology declaration
######################################################################

<https://w3id.org/energy-domain/edo/mappings/ifc>
    rdf:type owl:Ontology ;
    owl:imports <https://w3id.org/energy-domain/edo> ;

    rdfs:label "EDO IFC Mapping Ontology"@en ;
    rdfs:label "Ontologia de Mapeamento IFC da EDO"@pt-br ;

    dcterms:description "Ontology containing IFC-specific mapping annotations, controlled IFC references and materialisation rules for the Energy Domain Ontology."@en ;
    dcterms:description "Ontologia contendo anotações de mapeamento IFC, referências IFC controladas e regras de materialização IFC para a Energy Domain Ontology."@pt-br .

######################################################################
# 2) Root annotation for IFC mapping
######################################################################

edo-ifc:IFCMappingAnnotation
    rdf:type owl:AnnotationProperty ;

    rdfs:label "IFC Mapping Annotation"@en ;
    rdfs:label "Anotação de Mapeamento IFC"@pt-br ;

    skos:definition "Root annotation property for IFC-specific mapping metadata used to translate EDO concepts and relationships into IFC."@en ;
    skos:definition "Propriedade de anotação raiz para metadados específicos de mapeamento IFC usados para traduzir conceitos e relacionamentos da EDO para IFC."@pt-br ;

    dcterms:identifier "IFCMappingAnnotation" .

######################################################################
# 3) Generic IFC mapping annotations
######################################################################

edo-ifc:ifc_equivalentClass
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range edo-ifc:IFCEntity ;

    rdfs:label "IFC Equivalent Class"@en ;
    rdfs:label "Classe IFC Equivalente"@pt-br ;

    skos:definition "Indicates the controlled IFC entity used to materialise an EDO class or relationship."@en ;
    skos:definition "Indica a entidade IFC controlada usada para materializar uma classe ou relacionamento da EDO."@pt-br ;

    skos:altLabel "IFC Mapping Class"@en ;
    skos:altLabel "Classe de Mapeamento IFC"@pt-br ;

    dcterms:identifier "ifc_equivalentClass" .


edo-ifc:ifc_invertedDirection
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range xsd:boolean ;

    rdfs:label "IFC Inverted Direction"@en ;
    rdfs:label "Direção Invertida no IFC"@pt-br ;

    skos:definition "Indicates that the direction of an EDO relationship should be inverted when materialised as an IFC relationship."@en ;
    skos:definition "Indica que a direção de um relacionamento da EDO deve ser invertida quando materializada como relacionamento IFC."@pt-br ;

    skos:altLabel "Invert Mapping Direction"@en ;
    skos:altLabel "Inverter Direção do Mapeamento"@pt-br ;

    dcterms:identifier "ifc_invertedDirection" .


edo-ifc:ifc_subjectRole
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range edo-ifc:IFCAttributeRole ;

    rdfs:label "IFC Subject Role"@en ;
    rdfs:label "Papel do Sujeito no IFC"@pt-br ;

    skos:definition "Indicates the controlled IFC attribute role fulfilled by the subject of an EDO relationship when materialised in IFC."@en ;
    skos:definition "Indica o papel controlado de atributo IFC exercido pelo sujeito de um relacionamento da EDO quando materializado em IFC."@pt-br ;

    dcterms:identifier "ifc_subjectRole" .


edo-ifc:ifc_objectRole
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range edo-ifc:IFCAttributeRole ;

    rdfs:label "IFC Object Role"@en ;
    rdfs:label "Papel do Objeto no IFC"@pt-br ;

    skos:definition "Indicates the controlled IFC attribute role fulfilled by the object of an EDO relationship when materialised in IFC."@en ;
    skos:definition "Indica o papel controlado de atributo IFC exercido pelo objeto de um relacionamento da EDO quando materializado em IFC."@pt-br ;

    dcterms:identifier "ifc_objectRole" .

######################################################################
# 4) IFC mapping rule annotations
######################################################################

edo-ifc:ifc_mappingRule
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;

    rdfs:label "IFC Mapping Rule"@en ;
    rdfs:label "Regra de Mapeamento IFC"@pt-br ;

    skos:definition "Defines a conditional IFC materialisation rule for an EDO relationship."@en ;
    skos:definition "Define uma regra condicional de materialização IFC para um relacionamento da EDO."@pt-br ;

    dcterms:identifier "ifc_mappingRule" .


edo-ifc:sourceIfcEquivalentClass
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range edo-ifc:IFCEntity ;

    rdfs:label "Source IFC Equivalent Class"@en ;
    rdfs:label "Classe IFC Equivalente da Origem"@pt-br ;

    skos:definition "Specifies the controlled IFC entity expected for the source type of a relationship mapping rule."@en ;
    skos:definition "Especifica a entidade IFC controlada esperada para o tipo de origem de uma regra de mapeamento de relacionamento."@pt-br ;

    dcterms:identifier "sourceIfcEquivalentClass" .


edo-ifc:targetIfcEquivalentClass
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range edo-ifc:IFCEntity ;

    rdfs:label "Target IFC Equivalent Class"@en ;
    rdfs:label "Classe IFC Equivalente do Destino"@pt-br ;

    skos:definition "Specifies the controlled IFC entity expected for the target type of a relationship mapping rule."@en ;
    skos:definition "Especifica a entidade IFC controlada esperada para o tipo de destino de uma regra de mapeamento de relacionamento."@pt-br ;

    dcterms:identifier "targetIfcEquivalentClass" .


edo-ifc:sourceNotIfcEquivalentClass
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range edo-ifc:IFCEntity ;

    rdfs:label "Source Not IFC Equivalent Class"@en ;
    rdfs:label "Origem Não Equivalente à Classe IFC"@pt-br ;

    skos:definition "Specifies a controlled IFC entity that the source type must not have for a mapping rule to apply."@en ;
    skos:definition "Especifica uma entidade IFC controlada que o tipo de origem não deve ter para que uma regra de mapeamento se aplique."@pt-br ;

    dcterms:identifier "sourceNotIfcEquivalentClass" .


edo-ifc:targetNotIfcEquivalentClass
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range edo-ifc:IFCEntity ;

    rdfs:label "Target Not IFC Equivalent Class"@en ;
    rdfs:label "Destino Não Equivalente à Classe IFC"@pt-br ;

    skos:definition "Specifies a controlled IFC entity that the target type must not have for a mapping rule to apply."@en ;
    skos:definition "Especifica uma entidade IFC controlada que o tipo de destino não deve ter para que uma regra de mapeamento se aplique."@pt-br ;

    dcterms:identifier "targetNotIfcEquivalentClass" .


edo-ifc:realizingElementRequirement
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range edo-ifc:RealizingElementRequirement ;

    rdfs:label "Realizing Element Requirement"@en ;
    rdfs:label "Requisito de Elemento Realizador"@pt-br ;

    skos:definition "Indicates whether a mapping rule applies when realizing elements are present, absent, or irrelevant."@en ;
    skos:definition "Indica se uma regra de mapeamento se aplica quando elementos realizadores estão presentes, ausentes ou são irrelevantes."@pt-br ;

    dcterms:identifier "realizingElementRequirement" .


edo-ifc:realizingElementRole
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;
    rdfs:range edo-ifc:IFCAttributeRole ;

    rdfs:label "Realizing Element Role"@en ;
    rdfs:label "Papel do Elemento Realizador"@pt-br ;

    skos:definition "Specifies the controlled IFC attribute role used to store realizing elements in the materialised IFC relationship."@en ;
    skos:definition "Especifica o papel controlado de atributo IFC usado para armazenar elementos realizadores no relacionamento IFC materializado."@pt-br ;

    dcterms:identifier "realizingElementRole" .

######################################################################
# 5) IFC controlled reference annotations
######################################################################

edo-ifc:ifcEntityName
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;

    rdfs:label "IFC Entity Name"@en ;
    rdfs:label "Nome da Entidade IFC"@pt-br ;

    skos:definition "Stores the official IFC entity name used by translators when generating IFC data."@en ;
    skos:definition "Armazena o nome oficial da entidade IFC usado por tradutores ao gerar dados IFC."@pt-br ;

    dcterms:identifier "ifcEntityName" .


edo-ifc:ifcAttributeName
    rdf:type owl:AnnotationProperty ;
    rdfs:subPropertyOf edo-ifc:IFCMappingAnnotation ;

    rdfs:label "IFC Attribute Name"@en ;
    rdfs:label "Nome do Atributo IFC"@pt-br ;

    skos:definition "Stores the official IFC attribute name used by translators when filling IFC relationship roles."@en ;
    skos:definition "Armazena o nome oficial do atributo IFC usado por tradutores ao preencher papéis em relacionamentos IFC."@pt-br ;

    dcterms:identifier "ifcAttributeName" .

######################################################################
# 6) Controlled concepts for IFC entities and roles
######################################################################

edo-ifc:IFCEntity
    rdf:type owl:Class ;

    rdfs:label "IFC Entity"@en ;
    rdfs:label "Entidade IFC"@pt-br ;

    skos:definition "Controlled concept representing an IFC entity used by the EDO-IFC mapping ontology."@en ;
    skos:definition "Conceito controlado que representa uma entidade IFC usada pela ontologia de mapeamento EDO-IFC."@pt-br ;

    dcterms:identifier "IFCEntity" .


edo-ifc:IFCObjectEntity
    rdf:type owl:Class ;
    rdfs:subClassOf edo-ifc:IFCEntity ;

    rdfs:label "IFC Object Entity"@en ;
    rdfs:label "Entidade de Objeto IFC"@pt-br ;

    skos:definition "Controlled concept representing an IFC object entity used by the EDO-IFC mapping ontology."@en ;
    skos:definition "Conceito controlado que representa uma entidade de objeto IFC usada pela ontologia de mapeamento EDO-IFC."@pt-br ;

    dcterms:identifier "IFCObjectEntity" .


edo-ifc:IFCRelationshipEntity
    rdf:type owl:Class ;
    rdfs:subClassOf edo-ifc:IFCEntity ;

    rdfs:label "IFC Relationship Entity"@en ;
    rdfs:label "Entidade de Relacionamento IFC"@pt-br ;

    skos:definition "Controlled concept representing an IFC relationship entity used by the EDO-IFC mapping ontology."@en ;
    skos:definition "Conceito controlado que representa uma entidade de relacionamento IFC usada pela ontologia de mapeamento EDO-IFC."@pt-br ;

    dcterms:identifier "IFCRelationshipEntity" .


edo-ifc:IFCAttributeRole
    rdf:type owl:Class ;

    rdfs:label "IFC Attribute Role"@en ;
    rdfs:label "Papel de Atributo IFC"@pt-br ;

    skos:definition "Controlled concept representing an IFC attribute used as a role when materialising EDO relationships in IFC."@en ;
    skos:definition "Conceito controlado que representa um atributo IFC usado como papel ao materializar relacionamentos da EDO em IFC."@pt-br ;

    dcterms:identifier "IFCAttributeRole" .


edo-ifc:RealizingElementRequirement
    rdf:type owl:Class ;

    rdfs:label "Realizing Element Requirement"@en ;
    rdfs:label "Requisito de Elemento Realizador"@pt-br ;

    skos:definition "Controlled concept used to indicate whether realizing elements are required, absent, or irrelevant for an IFC mapping rule."@en ;
    skos:definition "Conceito controlado usado para indicar se elementos realizadores são requeridos, ausentes ou irrelevantes para uma regra de mapeamento IFC."@pt-br ;

    dcterms:identifier "RealizingElementRequirement" .

######################################################################
# 7) Controlled IFC relationship entities
######################################################################

edo-ifc:IfcRelAggregates
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCRelationshipEntity ;

    rdfs:label "IfcRelAggregates"@en ;
    edo-ifc:ifcEntityName "IfcRelAggregates" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelAggregates.htm> ;

    dcterms:identifier "IfcRelAggregates" .


edo-ifc:IfcRelNests
    rdf:type owl:NamedIndividual ;
