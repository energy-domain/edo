edo-ifc:IfcRelAssociatesMaterial
    rdf:type owl:NamedIndividual ;
    rdf:type edo-ifc:IFCRelationshipEntity ;

    rdfs:label "IfcRelAssociatesMaterial"@en ;
    edo-ifc:ifcEntityName "IfcRelAssociatesMaterial" ;

    rdfs:seeAlso <https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcRelAssociatesMaterial.htm> ;

